# ThreadMap — Environment Configuration
# Copy to .env and fill in your credentials

# ── App ──────────────────────────────────────────────────────────
TM_DEBUG=false
TM_SECRET_KEY=change-me-in-production

# ── PostgreSQL ───────────────────────────────────────────────────
TM_POSTGRES_HOST=localhost
TM_POSTGRES_PORT=5432
TM_POSTGRES_USER=threadmap
TM_POSTGRES_PASSWORD=threadmap
TM_POSTGRES_DB=threadmap

# ── Redis ────────────────────────────────────────────────────────
TM_REDIS_URL=redis://localhost:6379/0

# ── Kafka / Redpanda ────────────────────────────────────────────
TM_KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# ── OpenSearch ───────────────────────────────────────────────────
TM_OPENSEARCH_HOST=localhost
TM_OPENSEARCH_PORT=9200

# ── ClickHouse ───────────────────────────────────────────────────
TM_CLICKHOUSE_HOST=localhost
TM_CLICKHOUSE_PORT=8123

# ── S3 / MinIO ──────────────────────────────────────────────────
TM_S3_ENDPOINT_URL=http://localhost:9000
TM_S3_ACCESS_KEY=threadmap
TM_S3_SECRET_KEY=threadmap-secret

# ── Collector Credentials ────────────────────────────────────────
# Bluesky (no auth needed for Jetstream public firehose)
TM_BLUESKY_FIREHOSE_URL=wss://jetstream2.us-east.bsky.network/subscribe

# X (Twitter) — requires API v2 bearer token
TM_X_BEARER_TOKEN=

# Reddit — requires OAuth2 app credentials
TM_REDDIT_CLIENT_ID=
TM_REDDIT_CLIENT_SECRET=

# YouTube — requires Data API v3 key
TM_YOUTUBE_API_KEY=

# ── Enrichment ───────────────────────────────────────────────────
TM_SPACY_MODEL=en_core_web_sm
TM_EMBEDDING_MODEL=all-MiniLM-L6-v2
